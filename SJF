#include<stdio.h>
int main(){
int n,bt[10],wt[10],tat[10],i,j,tmp;
float awt=0,atat=0;
printf("Processes: ");scanf("%d",&n);
for(i=0;i<n;i++){printf("BT P%d: ",i+1);scanf("%d",&bt[i]);}
/* Sort by burst time (bubble sort) */
for(i=0;i<n-1;i++)
for(j=0;j<n-i-1;j++)
if(bt[j]>bt[j+1]){tmp=bt[j];bt[j]=bt[j+1];bt[j+1]=tmp;}
wt[0]=0;
for(i=1;i<n;i++) wt[i]=wt[i-1]+bt[i-1];
printf("\nP\tBT\tWT\tTAT\n");
for(i=0;i<n;i++){
tat[i]=wt[i]+bt[i]; awt+=wt[i]; atat+=tat[i];
printf("P%d\t%d\t%d\t%d\n",i+1,bt[i],wt[i],tat[i]);
}
printf("Avg WT=%.2f Avg TAT=%.2f\n",awt/n,atat/n);
}
