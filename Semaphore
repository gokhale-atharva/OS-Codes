#include<stdio.h>
#include<stdlib.h>
/* Simulating semaphores with int variables */
int mutex=1, full=0, empty=5, x=0;
void wait(int *s){(*s)--;}
void signal(int *s){(*s)++;}
void producer(){
wait(&mutex); wait(&empty);
x++; printf("Producer: item %d\n",x);
signal(&mutex); signal(&full);
}
void consumer(){
wait(&mutex); wait(&full);
printf("Consumer: item %d\n",x); x--;
signal(&mutex); signal(&empty);
}
int main(){
int ch;
while(1){
printf("1=Produce 2=Consume 3=Exit: ");scanf("%d",&ch);
if(ch==1){if(empty>0)producer();else printf("Buffer full!\n");}
else if(ch==2){if(full>0)consumer();else printf("Buffer empty!\n");}
else break;
}
}
