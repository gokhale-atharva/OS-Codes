#include<stdio.h>
int main(){
int bsize[10],psize[10],alloc[10],nb,np,i,j,bi;
printf("Blocks & Processes: ");scanf("%d%d",&nb,&np);
for(i=0;i<nb;i++){printf("Block %d: ",i+1);scanf("%d",&bsize[i]);}
for(i=0;i<np;i++){printf("Process %d: ",i+1);scanf("%d",&psize[i]);alloc[i]=-1;}
for(i=0;i<np;i++){
bi=-1;
for(j=0;j<nb;j++)
if(bsize[j]>=psize[i]&&(bi==-1||bsize[j]>bsize[bi])) bi=j;
if(bi!=-1){alloc[i]=bi+1;bsize[bi]-=psize[i];}
}
printf("\nProcess\tSize\tBlock\n");
for(i=0;i<np;i++)
printf("P%d\t%d\t%s%d\n",i+1,psize[i],alloc[i]==-1?"NA":"B",alloc[i]==-1?0:alloc[i]);
}
