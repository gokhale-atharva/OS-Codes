#include<stdio.h>
int main(){
int n,tq,bt[10],rem[10],wt[10]={0},tat[10],i,t=0,flag;
printf("Processes & Time Quantum: ");scanf("%d%d",&n,&tq);
for(i=0;i<n;i++){printf("BT P%d: ",i+1);scanf("%d",&bt[i]);rem[i]=bt[i];}
while(1){
flag=1;
for(i=0;i<n;i++){
if(rem[i]>0){flag=0;
if(rem[i]>tq){t+=tq;rem[i]-=tq;}
else{t+=rem[i];rem[i]=0;tat[i]=t;wt[i]=tat[i]-bt[i];}
}
}
if(flag)break;
}
float sw=0,st=0;
printf("\nP\tBT\tWT\tTAT\n");
for(i=0;i<n;i++){sw+=wt[i];st+=tat[i];
printf("P%d\t%d\t%d\t%d\n",i+1,bt[i],wt[i],tat[i]);}
printf("Avg WT=%.2f Avg TAT=%.2f\n",sw/n,st/n);
}
